{
  "expo": {
    "name": "rag-mobile",
    "slug": "rag-mobile",
    "version": "1.0.0",
    "assetBundlePatterns": ["assets/models/**"],
    "extra": {
      "eas": { "projectId": "3bc2d6d8-bac0-4689-a3b5-7e31f74417d5" }
    },
    "plugins": [
      "./plugins/withModelAssets",
      "./plugins/withOnnxRuntime",
      "expo-secure-store",
      "expo-dev-client",
      "expo-sqlite",
      "./plugins/withSqliteVec",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": ["https://repo1.maven.org/maven2/"],
            "extraProguardRules": "-keep class ai.onnxruntime.** { *; }",
            "packagingOptions": {
              "pickFirst": [
                "lib/arm64-v8a/libreactnative.so",
                "lib/x86_64/libreactnative.so",
                "lib/armeabi-v7a/libreactnative.so",
                "lib/x86/libreactnative.so"
              ]
            }
          }
        }
      ],
      "expo-asset"
    ],
    "android": {
      "package": "com.ragmobile"
    }
  }
}